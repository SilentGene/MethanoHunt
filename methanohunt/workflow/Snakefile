configfile: "config.yaml"

# Define markers globally
MARKERS = config.get("markers", ["McrA", "PmoA", "MmoX"])

# Determine targets
targets = [f"{config['output_dir']}/methanohunt_gene_classification.tsv"]

# Add extracted sequence targets
targets.extend([
    f"{config['output_dir']}/classified_sequences/McrA_methanogen.faa",
    f"{config['output_dir']}/classified_sequences/McrA_ANME.faa",
    f"{config['output_dir']}/classified_sequences/PmoA.faa",
    f"{config['output_dir']}/classified_sequences/MmoX.faa"
])

if config.get("nucl") and (config.get("reads_1") or config.get("samples")):
    targets.extend([
        f"{config['output_dir']}/RPKG/RPKG_individual_gene.tsv",
        f"{config['output_dir']}/RPKG/RPKG_marker_gene.tsv",
        f"{config['output_dir']}/RPKG/RPKG_marker_gene_subtype.tsv",
        f"{config['output_dir']}/MethanoHunt_report.html"
    ])

if config.get("run_tree"):
    targets.extend(expand(f"{config['output_dir']}/tree/{{marker}}.fasttree.nwk", marker=MARKERS))

# --- Helper rules to bridge wildcard-based subworkflow with single-input legacy behavior ---
rule setup_query:
    input: config["protein"]
    output: f"{config['output_dir']}/faa/query.faa"
    shell: "ln -sf $(realpath {input}) {output}"

rule finalize_classification:
    input: f"{config['output_dir']}/classification/query_methanohunt_gene_classification.tsv"
    output: f"{config['output_dir']}/methanohunt_gene_classification.tsv"
    shell: "cp {input} {output}"

rule finalize_sequences:
    input: f"{config['output_dir']}/classified_sequences/query_{{seq}}.faa"
    output: f"{config['output_dir']}/classified_sequences/{{seq}}.faa"
    shell: "cp {input} {output}"

rule finalize_tree:
    input: f"{config['output_dir']}/tree/query_{{marker}}.fasttree.nwk"
    output: f"{config['output_dir']}/tree/{{marker}}.fasttree.nwk"
    shell: "cp {input} {output}"
# ----------------------------------------------------------------------------------------

# Set default target
rule all:
    input: targets

# Include modular rules
include: "rules/hmm_mcrA.smk"
include: "rules/hmm_pmoA.smk"
include: "rules/hmm_mmoX.smk"
include: "rules/placement.smk"
include: "rules/classify.smk"
include: "rules/quant.smk"
include: "rules/vis.smk"
include: "rules/tree.smk"
include: "rules/extract.smk"

onsuccess:
    import os
    import glob
    
    # Check if we should keep BAM files (default is False/None -> Delete)
    if not config.get("keep_bam"):
        print("Cleaning up BAM files (default behavior)...")
        bam_dir = os.path.join(config['output_dir'], "bam")
        
        if os.path.exists(bam_dir):
            # Find .bam and .bam.bai files
            files_to_remove = glob.glob(os.path.join(bam_dir, "*.bam")) + \
                              glob.glob(os.path.join(bam_dir, "*.bam.bai"))
            
            removed_count = 0
            for f in files_to_remove:
                try:
                    os.remove(f)
                    removed_count += 1
                except Exception as e:
                    print(f"Warning: Could not remove {f}: {e}")
            
            if removed_count > 0:
                print(f"Removed {removed_count} BAM/BAI files.")
                
                # Create placeholder file
                placeholder = os.path.join(bam_dir, "removed_by_default")
                try:
                    with open(placeholder, "w") as f:
                        f.write("BAM files produced during the run were removed to save space.\n")
                        f.write("To keep them, run with --keep-bam flag.\n")
                except Exception as e:
                    print(f"Warning: Could not create placeholder file: {e}")

